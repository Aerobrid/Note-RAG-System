# ─────────────────────────────────────────────
#  rag-system - Environment Configuration
# ─────────────────────────────────────────────

# Switch between "gemini" or "ollama" at any time -> no code change needed
LLM_PROVIDER=gemini

# Get your free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_here
GEMINI_MODEL=gemini-2.5-flash 

# Ollama - used when LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b                  # General Q&A
OLLAMA_CODE_MODEL=qwen2.5-coder:7b        # Code understanding

# Storage
CHROMA_PATH=./chroma_db
NOTES_DIR=./notes                          # Drop files here, they get auto-indexed

# Embeddings (runs locally, no API key needed)
EMBED_MODEL=BAAI/bge-large-en-v1.5

# Reranker (cross-encoder, runs locally)
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Fine-tuning
FINETUNE_BASE_MODEL=unsloth/llama-3.2-3B-Instruct-bnb-4bit
FINETUNE_OUTPUT_DIR=./finetuned_model
FINETUNE_EPOCHS=3
FINETUNE_BATCH_SIZE=4

# CORS
ALLOWED_ORIGINS=http://localhost:3000