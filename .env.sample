# ─────────────────────────────────────────────
# LLM
# ─────────────────────────────────────────────
# Switch between "gemini" or "ollama" — no code change needed
LLM_PROVIDER=gemini

# --- Gemini (when LLM_PROVIDER=gemini) ---
# Key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GOOGLE_API_VERSION=v1

# --- Ollama (when LLM_PROVIDER=ollama) ---
# Local backend (uvicorn on host):     http://localhost:11434
# Docker backend + Ollama on host:     http://host.docker.internal:11434
# Docker backend + Ollama in Compose:  http://ollama:11434  (use: docker compose --profile ollama up -d)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_CODE_MODEL=qwen2.5-coder:7b

# ─────────────────────────────────────────────
# Storage (Compose sets CHROMA_PATH / NOTES_DIR inside containers)
# ─────────────────────────────────────────────
CHROMA_PATH=./chroma_db
NOTES_DIR=./notes

# ─────────────────────────────────────────────
# Embeddings & reranking (local sentence-transformers; no API key)
# ─────────────────────────────────────────────
EMBED_MODEL=BAAI/bge-large-en-v1.5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# Code Embedding Model
CODE_EMBED_MODEL=microsoft/codebert-base

# ─────────────────────────────────────────────
# Fine-tuning (optional — implement when you wire this path)
# ─────────────────────────────────────────────
FINETUNE_BASE_MODEL=unsloth/llama-3.2-3B-Instruct-bnb-4bit
FINETUNE_OUTPUT_DIR=./finetuned_model
FINETUNE_EPOCHS=3
FINETUNE_BATCH_SIZE=4

# ─────────────────────────────────────────────
# Next.js (browser → API). Needed for Docker / production builds.
# ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─────────────────────────────────────────────
# CORS — comma-separated origins for the UI
# ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
